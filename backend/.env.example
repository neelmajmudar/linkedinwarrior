# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Apify
APIFY_API_TOKEN=your_apify_api_token

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (embeddings)
OPENAI_API_KEY=your_openai_api_key

# Unipile
UNIPILE_DSN=https://api30.unipile.com:
UNIPILE_API_KEY=your_unipile_api_key

# Redis (required for scalable Celery scheduling; omit to use APScheduler fallback)
REDIS_URL=redis://localhost:6379/0

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Unipile Email Webhook (set a random secret for verifying webhook authenticity)
UNIPILE_WEBHOOK_SECRET=your_webhook_secret_here

# Resend (transactional email for team invites)
RESEND_API_KEY=your_resend_api_key

# Scaling (production tuning)
WEB_WORKERS=4                    # Gunicorn worker processes (default: 2*CPU+1, max 8)
OPENAI_MAX_CONCURRENCY=10       # Max concurrent OpenAI API calls per process
CELERY_WORKER_CONCURRENCY=8     # Default Celery worker concurrency (overridable via CLI)
